              <hashTree>
                <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Check eligibility Point &amp; Amount (before Credit)" enabled="true">
                  <stringProp name="HTTPSampler.domain">${base_url}</stringProp>
                  <stringProp name="HTTPSampler.path">/api/v0/projects/${project_key}/wallets/${currentWalletID}/eligibility</stringProp>
                  <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
