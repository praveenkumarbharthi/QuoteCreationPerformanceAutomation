            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor (Store Wallet IDs)" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Extract wallet ID from the response, check if the response contains the expected field
try {
    def response = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString()) // Parse the response
    def walletId = response.walletId // Assuming &apos;walletId&apos; is the field in the response

    // If walletId is present, store it for the next request
    if (walletId != null) {
        vars.put(&quot;currentWalletID&quot;, walletId) // Store the walletId as a JMeter variable
        log.info(&quot;Stored Current Wallet ID: &quot; + walletId) // Log the walletId
    } else {
        log.warn(&quot;No walletId found in the response!&quot;) // Warn if walletId is missing in response
    }
} catch (Exception e) {
    log.error(&quot;Error parsing response: &quot; + e.getMessage()) // Handle any errors that may occur
}</stringProp>
            </JSR223PostProcessor>
