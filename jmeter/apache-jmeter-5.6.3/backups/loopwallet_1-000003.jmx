            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="PostProcessor_CaptureWalletId" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Get the response as a string  
def response = prev.getResponseDataAsString()   

// Parse the JSON response  
def jsonData = new groovy.json.JsonSlurper().parseText(response)   

// Check if walletId exists and set it as a JMeter variable  
if (jsonData.walletId != null) {  
    vars.put(&quot;walletId&quot;, jsonData.walletId.toString()) // Store the walletId as a JMeter variable  
    log.info(&quot;Captured walletId: &quot; + jsonData.walletId) // Log the captured walletId  
} else {  
    log.warn(&quot;walletId not found in the response&quot;) // Log a warning if walletId is not present  
}</stringProp>
            </JSR223PostProcessor>
