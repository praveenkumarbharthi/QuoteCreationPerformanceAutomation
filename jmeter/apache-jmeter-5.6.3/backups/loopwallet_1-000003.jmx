                    <stringProp name="script">// Retrieve the wallet ID stored after creation
def currentWalletID = vars.get(&quot;currentWalletID&quot;)

// Ensure we have a valid wallet ID
if (currentWalletID == null || currentWalletID.isEmpty()) {
    log.error(&quot;No wallet ID found! Wallet creation might have failed.&quot;)
    return
}

// Store in JMeter variable for request use
