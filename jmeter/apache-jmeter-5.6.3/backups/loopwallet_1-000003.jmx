            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">// Parse the response body as JSON  
def responseJson = new groovy.json.JsonSlurper().parseText(prev.getResponseDataAsString())  

// Extracting the campaignId from the response and setting it as a JMeter variable  
def campaignId = responseJson.campaignId  
vars.put(&quot;campaignId&quot;, campaignId)  

// Check if earningRuleDetails array exists and has at least one item  
def earningRuleDetails = responseJson.earningRuleDetails  
if (earningRuleDetails &amp;&amp; earningRuleDetails.size() &gt; 0) {  
    // Capture the id of the first earningRuleDetail  
    def earningRuleId = earningRuleDetails[0].id  
    
    // Store the captured id in a JMeter variable  
    vars.put(&quot;earningRuleId&quot;, earningRuleId)  
    
    // Log the captured id for debugging  
    log.info(&quot;Captured earningRuleDetails[0].id: &quot; + earningRuleId)  
} else {  
    log.error(&quot;earningRuleDetails array is empty or does not exist.&quot;)  
}</stringProp>
            </JSR223PostProcessor>
