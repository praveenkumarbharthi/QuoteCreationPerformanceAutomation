          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="PostProcessor_CaptureToken">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Get the response body as a string  
def responseBody = prev.getResponseDataAsString()  

// Parse the JSON response  
def jsonData = new groovy.json.JsonSlurper().parseText(responseBody)  

// Store the access_token if it exists  
if (jsonData.access_token != null) {  
    props.put(&quot;myjwt&quot;, jsonData.access_token.toString()) // Store the token globally  
    log.info(&quot;Captured access_token: &quot; + jsonData.access_token) // Log the captured token  
} else {  
    log.warn(&quot;access_token not found in the response&quot;)
}</stringProp>
          </JSR223PostProcessor>
