                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">// Get the response body as a string  
def responseBody = prev.getResponseDataAsString()  

// Parse the JSON response  
def jsonData = new groovy.json.JsonSlurper().parseText(responseBody)  

// Check if walletId exists and set it as a JMeter variable  
if (jsonData.walletId != null) {  
    vars.put(&quot;walletId&quot;, jsonData.walletId.toString()) // Store the walletId as a JMeter variable  
    log.info(&quot;Captured walletId: &quot; + jsonData.walletId) // Log the captured walletId  
} else {  
    log.warn(&quot;walletId not found in the response&quot;) // Log a warning if walletId is not present  
}  

// Check if transactionId exists and set it as a JMeter variable  
if (jsonData.transactionId != null) {  
    vars.put(&quot;transactionId&quot;, jsonData.transactionId.toString()) // Store the transactionId as a JMeter variable  
    log.info(&quot;Captured transactionId: &quot; + jsonData.transactionId) // Log the captured transactionId  
} else {  
    log.warn(&quot;transactionId not found in the response&quot;) // Log a warning if transactionId is not present  
}</stringProp>
                  </JSR223PostProcessor>
