// Create a static set to hold unique customer IDs
if (vars.get(&quot;customerIdSet&quot;) == null) {
    vars.putObject(&quot;customerIdSet&quot;, [] as Set)
}

// Function to generate a random requestId of 8 digits
def requestId = (10000000 + (int)(Math.random() * 90000000)) // Generates a random 8-digit number
vars.put(&quot;requestId&quot;, requestId.toString()) // Store as a JMeter variable

// Generate unique customerId with timestamp and random string
def generateUniqueCustomerId() {
    def prefix = &quot;praveen&quot;
    String customerId
    def customerIdSet = vars.getObject(&quot;customerIdSet&quot;) as Set // Get the unique customer ID set

    do {
        // Generate a random number
        def randomNumber = (1000000 + (int)(Math.random() * 90000000)) // 7-digit random number

        // Get current timestamp
        def timestamp = System.currentTimeMillis() // Current time in milliseconds

        // Generate a random UUID string (first 8 characters)
        def uniqueSuffix = UUID.randomUUID().toString().substring(0, 8)

        // Combine all parts to generate a unique customerId
        customerId = &quot;${prefix}${randomNumber}${timestamp}${uniqueSuffix}&quot;

    } while (customerIdSet.contains(customerId)) // Check for uniqueness

    customerIdSet.add(customerId) // Add to the set of customer IDs
    vars.putObject(&quot;customerIdSet&quot;, customerIdSet) // Update the set back to JMeter variables
    return customerId
}

// Generate the ID and set it as a JMeter variable
def customerId = generateUniqueCustomerId()
vars.put(&quot;customer_id&quot;, customerId) // Store the customerId as a JMeter variable

// Log the generated customer ID in the JMeter log
log.info(&quot;Generated Customer ID: ${customerId}&quot;)

// Array of sample surnames
def surnames = [
    &quot;Smith&quot;, &quot;Johnson&quot;, &quot;Williams&quot;, &quot;Jones&quot;, &quot;Brown&quot;,
    &quot;Davis&quot;, &quot;Garcia&quot;, &quot;Rodriguez&quot;, &quot;Martinez&quot;, &quot;Hernandez&quot;
]

// Generate a random index to select a surname
def randomIndex = (int)(Math.random() * surnames.size())

// Create the customerName by combining &quot;Praveen&quot; with a random surname
def customerName = &quot;Praveen &quot; + surnames[randomIndex]

// Set the customerName as a JMeter variable
vars.put(&quot;customerName&quot;, customerName)

// Log the customerName for debugging purposes
log.info(&quot;Generated customerName: ${customerName}&quot;)</stringProp>
