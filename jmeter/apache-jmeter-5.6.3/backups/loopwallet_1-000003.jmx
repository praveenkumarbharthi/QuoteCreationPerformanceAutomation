      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="generateRandomCampaignName &amp; endDate &amp; startDate" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">// Function to generate a random campaign name  
def generateRandomCampaignName() {  
    def campaignNames = [  
        &quot;Spring Sale&quot;,  
        &quot;Summer Fest&quot;,  
        &quot;Autumn Boost&quot;,  
        &quot;Winter Wonderland&quot;,  
        &quot;Holiday Joy&quot;,  
        &quot;New Year Launch&quot;,  
        &quot;Flash Sale&quot;,  
        &quot;Clearance Event&quot;,  
        &quot;Customer Appreciation&quot;,  
        &quot;Mega Markdown Madness&quot;,  
        &quot;Loyalty Rewards&quot;,  
        &quot;Fall For Savings&quot;,  
        &quot;Price Drop Party&quot;,  
        &quot;Epic End-of-Season Sale&quot;  
    ]  

    // Get a random campaign name from the array  
    def randomIndex = new Random().nextInt(campaignNames.size())  
    return campaignNames[randomIndex]  
}  

// Concatenate initial from Praveen with random campaign name  
def initial = &quot;Praveen&quot;  
def randomCampaignName = generateRandomCampaignName()  
def generatedName = &quot;${initial} - ${randomCampaignName}&quot;  

// Set the generated name as a collection variable  
vars.put(&quot;generatedName&quot;, generatedName)  

// Optionally log the result to the JMeter log for debugging  
log.info(&quot;Generated Name: &quot; + generatedName)  

// Function to format the date to &quot;YYYY-MM-DDTHH:mm:ssZ&quot;  
def formatDate(date) {  
    return date.format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&apos;Z&apos;&quot;)  
}  

// Get the current date  
def currentDate = new Date()  

// Calculate future dates  
def startDate = currentDate + 7 // 1 week from now  
def endDate = startDate + 7 // 2 weeks from current date  

// Format the dates  
def formattedStartDate = formatDate(startDate)  
def formattedEndDate = formatDate(endDate)  

// Set the dates as collection variables  
vars.put(&quot;startDate&quot;, formattedStartDate)  
vars.put(&quot;endDate&quot;, formattedEndDate)  

// Log the results to JMeter log for debugging  
log.info(&quot;Start Date: &quot; + formattedStartDate)  
log.info(&quot;End Date: &quot; + formattedEndDate)</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
