      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="PreProcessor_RandomCustomerNameANDId" enabled="false">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="script">// Create a static set to hold unique customer IDs  
if (vars.get(&quot;customerIdSet&quot;) == null) {  
    vars.putObject(&quot;customerIdSet&quot;, [] as Set)  
}  

// Function to generate a random requestId of 8 digits  
def requestId = (10000000 + (int)(Math.random() * 90000000)) // Generates a random 8-digit number  
vars.put(&quot;requestId&quot;, requestId.toString()) // Store as a JMeter variable  

// Generate unique customerId  
def generateUniqueCustomerId() {  
    def prefix = &quot;praveen&quot;  
    String customerId  
    def customerIdSet = vars.getObject(&quot;customerIdSet&quot;) as Set // Get the unique customer ID set  
    
    do {  
        def randomNumber = (10000 + (int)(Math.random() * 90000)) // Generates a number between 10000 and 99999  
        customerId = &quot;${prefix}${randomNumber}&quot;  
    } while (customerIdSet.contains(customerId)) // Check for uniqueness  
    
    customerIdSet.add(customerId) // Add to the set of customer IDs  
    vars.putObject(&quot;customerIdSet&quot;, customerIdSet) // Update the set back to JMeter variables  
    return customerId  
}  

// Generate the ID and set it as a JMeter variable  
def customerId = generateUniqueCustomerId()  
vars.put(&quot;customer_id&quot;, customerId)  

// Log the generated customer ID in the JMeter log  
log.info(&quot;Generated Customer ID: ${customerId}&quot;)  

// Array of sample surnames  
def surnames = [  
    &quot;Smith&quot;, &quot;Johnson&quot;, &quot;Williams&quot;, &quot;Jones&quot;, &quot;Brown&quot;,   
    &quot;Davis&quot;, &quot;Garcia&quot;, &quot;Rodriguez&quot;, &quot;Martinez&quot;, &quot;Hernandez&quot;  
]  

// Generate a random index to select a surname  
def randomIndex = (int)(Math.random() * surnames.size())  

// Create the customerName by combining &quot;Praveen&quot; with a random surname  
def customerName = &quot;Praveen &quot; + surnames[randomIndex]  

// Set the customerName as a JMeter variable  
vars.put(&quot;customerName&quot;, customerName)  

// Optional: Log the customerName for debugging purposes  
log.info(&quot;Generated customerName: ${customerName}&quot;)</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="PreProcessor_RandomKeyID">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="script">// Generate a random requestId of 9 digits  
def requestId = (100000000 + (int)(Math.random() * 900000000)) // Generates a random 9-digit number  
vars.put(&quot;requestId&quot;, requestId.toString()) // Store as a JMeter variable  

// Function to generate a random string of a specified length  
def generateRandomString(int length) {  
    def characters = &apos;ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789&apos;  
    def result = new StringBuilder() // Use StringBuilder for efficiency  
    for (int i = 0; i &lt; length; i++) {  
        int randomIndex = (int)(Math.random() * characters.length())  
        result.append(characters.charAt(randomIndex))  
    }  
    return result.toString()  
}  

// Generate a random key (you can adjust the length as needed)  
def randomKey = generateRandomString(16)  
vars.put(&quot;keynumber&quot;, randomKey) // Store as a JMeter variable  
log.info(&quot;Generated random key: ${randomKey}&quot;) // Log the generated random key</stringProp>
        </JSR223PreProcessor>
